{
  "files": [],
  "references": [
    { "path": "./tsconfig.node.json" },
    { "path": "./tsconfig.app.json" },
    { "path": "./tsconfig.vitest.json" }
  ],
  "compilerOptions": {
    "composite": true,
    "noEmit": true, // 主配置不输出任何文件，仅做项目引用
    "baseUrl": ".",
    "paths": { "@/*": ["src/*"] },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": [
    // 1. 包含你自定义的 .d.ts（优先级最高）
    "src/types/**/*.d.ts",
    // 2. 包含业务代码（确保组件/脚本能关联自定义类型）
    "src/**/*.vue",
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": ["node_modules", "temp/**/*", "temp/declarations/**/*"]
}
